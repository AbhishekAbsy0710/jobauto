# ============================================
# JobAuto - Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# Ollama (Local LLM - Free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# JSearch API (Free tier via RapidAPI - 200 req/month)
# Get free key: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Telegram Bot (Free - create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Application
PORT=3000
NODE_ENV=development

# Job Search Config
SEARCH_KEYWORDS=DevOps Engineer,Cloud Engineer,Full Stack Developer,Data Engineer,AI Engineer
SEARCH_LOCATIONS=Switzerland,Germany,Remote

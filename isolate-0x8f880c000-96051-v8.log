script-source,97,node:internal/util/parse_args/parse_args,'use strict';\n\nconst {\n  ArrayPrototypeForEach\x2C\n  ArrayPrototypeIncludes\x2C\n  ArrayPrototypeMap\x2C\n  ArrayPrototypePush\x2C\n  ArrayPrototypePushApply\x2C\n  ArrayPrototypeShift\x2C\n  ArrayPrototypeSlice\x2C\n  ArrayPrototypeUnshiftApply\x2C\n  ObjectEntries\x2C\n  ObjectPrototypeHasOwnProperty: ObjectHasOwn\x2C\n  StringPrototypeCharAt\x2C\n  StringPrototypeIndexOf\x2C\n  StringPrototypeSlice\x2C\n  StringPrototypeStartsWith\x2C\n} = primordials;\n\nconst {\n  validateArray\x2C\n  validateBoolean\x2C\n  validateBooleanArray\x2C\n  validateObject\x2C\n  validateString\x2C\n  validateStringArray\x2C\n  validateUnion\x2C\n} = require('internal/validators');\n\nconst {\n  findLongOptionForShort\x2C\n  isLoneLongOption\x2C\n  isLoneShortOption\x2C\n  isLongOptionAndValue\x2C\n  isOptionValue\x2C\n  isOptionLikeValue\x2C\n  isShortOptionAndValue\x2C\n  isShortOptionGroup\x2C\n  useDefaultValueOption\x2C\n  objectGetOwn\x2C\n  optionsGetOwn\x2C\n} = require('internal/util/parse_args/utils');\n\nconst {\n  codes: {\n    ERR_INVALID_ARG_VALUE\x2C\n    ERR_PARSE_ARGS_INVALID_OPTION_VALUE\x2C\n    ERR_PARSE_ARGS_UNEXPECTED_POSITIONAL\x2C\n    ERR_PARSE_ARGS_UNKNOWN_OPTION\x2C\n  }\x2C\n} = require('internal/errors');\n\nconst {\n  kEmptyObject\x2C\n} = require('internal/util');\n\n\nfunction getMainArgs() {\n  // Work out where to slice process.argv for user supplied arguments.\n\n  // Check node options for scenarios where user CLI args follow executable.\n  const execArgv = process.execArgv;\n  if (ArrayPrototypeIncludes(execArgv\x2C '-e') ||\n      ArrayPrototypeIncludes(execArgv\x2C '--eval') ||\n      ArrayPrototypeIncludes(execArgv\x2C '-p') ||\n      ArrayPrototypeIncludes(execArgv\x2C '--print')) {\n    return ArrayPrototypeSlice(process.argv\x2C 1);\n  }\n\n  // Normally first two arguments are executable and script\x2C then CLI arguments\n  return ArrayPrototypeSlice(process.argv\x2C 2);\n}\n\n/**\n * In strict mode\x2C throw for possible usage errors like --foo --bar\n * @param {object} token - from tokens as available from parseArgs\n */\nfunction checkOptionLikeValue(token) {\n  if (!token.inlineValue && isOptionLikeValue(token.value)) {\n    // Only show short example if user used short option.\n    const example = StringPrototypeStartsWith(token.rawName\x2C '--') ?\n      `'${token.rawName}=-XYZ'` :\n      `'--${token.name}=-XYZ' or '${token.rawName}-XYZ'`;\n    const errorMessage = `Option '${token.rawName}' argument is ambiguous.\nDid you forget to specify the option argument for '${token.rawName}'?\nTo specify an option argument starting with a dash use ${example}.`;\n    throw new ERR_PARSE_ARGS_INVALID_OPTION_VALUE(errorMessage);\n  }\n}\n\n/**\n * In strict mode\x2C throw for usage errors.\n * @param {object} config - from config passed to parseArgs\n * @param {object} token - from tokens as available from parseArgs\n */\nfunction checkOptionUsage(config\x2C token) {\n  let tokenName = token.name;\n  if (!ObjectHasOwn(config.options\x2C tokenName)) {\n    // Check for negated boolean option.\n    if (config.allowNegative && StringPrototypeStartsWith(tokenName\x2C 'no-')) {\n      tokenName = StringPrototypeSlice(tokenName\x2C 3);\n      if (!ObjectHasOwn(config.options\x2C tokenName) || optionsGetOwn(config.options\x2C tokenName\x2C 'type') !== 'boolean') {\n        throw new ERR_PARSE_ARGS_UNKNOWN_OPTION(\n          token.rawName\x2C config.allowPositionals);\n      }\n    } else {\n      throw new ERR_PARSE_ARGS_UNKNOWN_OPTION(\n        token.rawName\x2C config.allowPositionals);\n    }\n  }\n\n  const short = optionsGetOwn(config.options\x2C tokenName\x2C 'short');\n  const shortAndLong = `${short ? `-${short}\x2C ` : ''}--${tokenName}`;\n  const type = optionsGetOwn(config.options\x2C tokenName\x2C 'type');\n  if (type === 'string' && typeof token.value !== 'string') {\n    throw new ERR_PARSE_ARGS_INVALID_OPTION_VALUE(`Option '${shortAndLong} <value>' argument missing`);\n  }\n  // (Idiomatic test for undefined||null\x2C expecting undefined.)\n  if (type === 'boolean' && token.value != null) {\n    throw new ERR_PARSE_ARGS_INVALID_OPTION_VALUE(`Option '${shortAndLong}' does not take an argument`);\n  }\n}\n\n\n/**\n * Store the option value in `values`.\n * @param {object} token - from tokens as available from parseArgs\n * @param {object} options - option configs\x2C from parseArgs({ options })\n * @param {object} values - option values returned in `values` by parseArgs\n * @param {boolean} allowNegative - allow negative optinons if true\n */\nfunction storeOption(token\x2C options\x2C values\x2C allowNegative) {\n  let longOption = token.name;\n  let optionValue = token.value;\n  if (longOption === '__proto__') {\n    return; // No. Just no.\n  }\n\n  if (allowNegative && StringPrototypeStartsWith(longOption\x2C 'no-') && optionValue === undefined) {\n    // Boolean option negation: --no-foo\n    longOption = StringPrototypeSlice(longOption\x2C 3);\n    token.name = longOption;\n    optionValue = false;\n  }\n\n  // We store based on the option value rather than option type\x2C\n  // preserving the users intent for author to deal with.\n  const newValue = optionValue ?? true;\n  if (optionsGetOwn(options\x2C longOption\x2C 'multiple')) {\n    // Always store value in array\x2C including for boolean.\n    // values[longOption] starts out not present\x2C\n    // first value is added as new array [newValue]\x2C\n    // subsequent values are pushed to existing array.\n    // (note: values has null prototype\x2C so simpler usage)\n    if (values[longOption]) {\n      ArrayPrototypePush(values[longOption]\x2C newValue);\n    } else {\n      values[longOption] = [newValue];\n    }\n  } else {\n    values[longOption] = newValue;\n  }\n}\n\n/**\n * Store the default option value in `values`.\n * @param {string} longOption - long option name e.g. 'foo'\n * @param {string\n *         | boolean\n *         | string[]\n *         | boolean[]} optionValue - default value from option config\n * @param {object} values - option values returned in `values` by parseArgs\n */\nfunction storeDefaultOption(longOption\x2C optionValue\x2C values) {\n  if (longOption === '__proto__') {\n    return; // No. Just no.\n  }\n\n  values[longOption] = optionValue;\n}\n\n/**\n * Process args and turn into identified tokens:\n * - option (along with value\x2C if any)\n * - positional\n * - option-terminator\n * @param {string[]} args - from parseArgs({ args }) or mainArgs\n * @param {object} options - option configs\x2C from parseArgs({ options })\n */\nfunction argsToTokens(args\x2C options) {\n  const tokens = [];\n  let index = -1;\n  let groupCount = 0;\n\n  const remainingArgs = ArrayPrototypeSlice(args);\n  while (remainingArgs.length > 0) {\n    const arg = ArrayPrototypeShift(remainingArgs);\n    const nextArg = remainingArgs[0];\n    if (groupCount > 0)\n      groupCount--;\n    else\n      index++;\n\n    // Check if `arg` is an options terminator.\n    // Guideline 10 in https://pubs.opengroup.org/onlinepubs/9699919799/basedefs/V1_chap12.html\n    if (arg === '--') {\n      // Everything after a bare '--' is considered a positional argument.\n      ArrayPrototypePush(tokens\x2C { kind: 'option-terminator'\x2C index });\n      ArrayPrototypePushApply(\n        tokens\x2C ArrayPrototypeMap(remainingArgs\x2C (arg) => {\n          return { kind: 'positional'\x2C index: ++index\x2C value: arg };\n        })\x2C\n      );\n      break; // Finished processing args\x2C leave while loop.\n    }\n\n    if (isLoneShortOption(arg)) {\n      // e.g. '-f'\n      const shortOption = StringPrototypeCharAt(arg\x2C 1);\n      const longOption = findLongOptionForShort(shortOption\x2C options);\n      let value;\n      let inlineValue;\n      if (optionsGetOwn(options\x2C longOption\x2C 'type') === 'string' &&\n          isOptionValue(nextArg)) {\n        // e.g. '-f'\x2C 'bar'\n        value = ArrayPrototypeShift(remainingArgs);\n        inlineValue = false;\n      }\n      ArrayPrototypePush(\n        tokens\x2C\n        { kind: 'option'\x2C name: longOption\x2C rawName: arg\x2C\n          index\x2C value\x2C inlineValue });\n      if (value != null) ++index;\n      continue;\n    }\n\n    if (isShortOptionGroup(arg\x2C options)) {\n      // Expand -fXzy to -f -X -z -y\n      const expanded = [];\n      for (let index = 1; index < arg.length; index++) {\n        const shortOption = StringPrototypeCharAt(arg\x2C index);\n        const longOption = findLongOptionForShort(shortOption\x2C options);\n        if (optionsGetOwn(options\x2C longOption\x2C 'type') !== 'string' ||\n          index === arg.length - 1) {\n          // Boolean option\x2C or last short in group. Well formed.\n          ArrayPrototypePush(expanded\x2C `-${shortOption}`);\n        } else {\n          // String option in middle. Yuck.\n          // Expand -abfFILE to -a -b -fFILE\n          ArrayPrototypePush(expanded\x2C `-${StringPrototypeSlice(arg\x2C index)}`);\n          break; // finished short group\n        }\n      }\n      ArrayPrototypeUnshiftApply(remainingArgs\x2C expanded);\n      groupCount = expanded.length;\n      continue;\n    }\n\n    if (isShortOptionAndValue(arg\x2C options)) {\n      // e.g. -fFILE\n      const shortOption = StringPrototypeCharAt(arg\x2C 1);\n      const longOption = findLongOptionForShort(shortOption\x2C options);\n      const value = StringPrototypeSlice(arg\x2C 2);\n      ArrayPrototypePush(\n        tokens\x2C\n        { kind: 'option'\x2C name: longOption\x2C rawName: `-${shortOption}`\x2C\n          index\x2C value\x2C inlineValue: true });\n      continue;\n    }\n\n    if (isLoneLongOption(arg)) {\n      // e.g. '--foo'\n      const longOption = StringPrototypeSlice(arg\x2C 2);\n      let value;\n      let inlineValue;\n      if (optionsGetOwn(options\x2C longOption\x2C 'type') === 'string' &&\n          isOptionValue(nextArg)) {\n        // e.g. '--foo'\x2C 'bar'\n        value = ArrayPrototypeShift(remainingArgs);\n        inlineValue = false;\n      }\n      ArrayPrototypePush(\n        tokens\x2C\n        { kind: 'option'\x2C name: longOption\x2C rawName: arg\x2C\n          index\x2C value\x2C inlineValue });\n      if (value != null) ++index;\n      continue;\n    }\n\n    if (isLongOptionAndValue(arg)) {\n      // e.g. --foo=bar\n      const equalIndex = StringPrototypeIndexOf(arg\x2C '=');\n      const longOption = StringPrototypeSlice(arg\x2C 2\x2C equalIndex);\n      const value = StringPrototypeSlice(arg\x2C equalIndex + 1);\n      ArrayPrototypePush(\n        tokens\x2C\n        { kind: 'option'\x2C name: longOption\x2C rawName: `--${longOption}`\x2C\n          index\x2C value\x2C inlineValue: true });\n      continue;\n    }\n\n    ArrayPrototypePush(tokens\x2C { kind: 'positional'\x2C index\x2C value: arg });\n  }\n  return tokens;\n}\n\nconst parseArgs = (config = kEmptyObject) => {\n  const args = objectGetOwn(config\x2C 'args') ?? getMainArgs();\n  const strict = objectGetOwn(config\x2C 'strict') ?? true;\n  const allowPositionals = objectGetOwn(config\x2C 'allowPositionals') ?? !strict;\n  const returnTokens = objectGetOwn(config\x2C 'tokens') ?? false;\n  const allowNegative = objectGetOwn(config\x2C 'allowNegative') ?? false;\n  const options = objectGetOwn(config\x2C 'options') ?? { __proto__: null };\n  // Bundle these up for passing to strict-mode checks.\n  const parseConfig = { args\x2C strict\x2C options\x2C allowPositionals\x2C allowNegative };\n\n  // Validate input configuration.\n  validateArray(args\x2C 'args');\n  validateBoolean(strict\x2C 'strict');\n  validateBoolean(allowPositionals\x2C 'allowPositionals');\n  validateBoolean(returnTokens\x2C 'tokens');\n  validateBoolean(allowNegative\x2C 'allowNegative');\n  validateObject(options\x2C 'options');\n  ArrayPrototypeForEach(\n    ObjectEntries(options)\x2C\n    ({ 0: longOption\x2C 1: optionConfig }) => {\n      validateObject(optionConfig\x2C `options.${longOption}`);\n\n      // type is required\n      const optionType = objectGetOwn(optionConfig\x2C 'type');\n      validateUnion(optionType\x2C `options.${longOption}.type`\x2C ['string'\x2C 'boolean']);\n\n      if (ObjectHasOwn(optionConfig\x2C 'short')) {\n        const shortOption = optionConfig.short;\n        validateString(shortOption\x2C `options.${longOption}.short`);\n        if (shortOption.length !== 1) {\n          throw new ERR_INVALID_ARG_VALUE(\n            `options.${longOption}.short`\x2C\n            shortOption\x2C\n            'must be a single character'\x2C\n          );\n        }\n      }\n\n      const multipleOption = objectGetOwn(optionConfig\x2C 'multiple');\n      if (ObjectHasOwn(optionConfig\x2C 'multiple')) {\n        validateBoolean(multipleOption\x2C `options.${longOption}.multiple`);\n      }\n\n      const defaultValue = objectGetOwn(optionConfig\x2C 'default');\n      if (defaultValue !== undefined) {\n        let validator;\n        switch (optionType) {\n          case 'string':\n            validator = multipleOption ? validateStringArray : validateString;\n            break;\n\n          case 'boolean':\n            validator = multipleOption ? validateBooleanArray : validateBoolean;\n            break;\n        }\n        validator(defaultValue\x2C `options.${longOption}.default`);\n      }\n    }\x2C\n  );\n\n  // Phase 1: identify tokens\n  const tokens = argsToTokens(args\x2C options);\n\n  // Phase 2: process tokens into parsed option values and positionals\n  const result = {\n    values: { __proto__: null }\x2C\n    positionals: []\x2C\n  };\n  if (returnTokens) {\n    result.tokens = tokens;\n  }\n  ArrayPrototypeForEach(tokens\x2C (token) => {\n    if (token.kind === 'option') {\n      if (strict) {\n        checkOptionUsage(parseConfig\x2C token);\n        checkOptionLikeValue(token);\n      }\n      storeOption(token\x2C options\x2C result.values\x2C parseConfig.allowNegative);\n    } else if (token.kind === 'positional') {\n      if (!allowPositionals) {\n        throw new ERR_PARSE_ARGS_UNEXPECTED_POSITIONAL(token.value);\n      }\n      ArrayPrototypePush(result.positionals\x2C token.value);\n    }\n  });\n\n  // Phase 3: fill in default values for missing args\n  ArrayPrototypeForEach(ObjectEntries(options)\x2C ({ 0: longOption\x2C\n                                                   1: optionConfig }) => {\n    const mustSetDefault = useDefaultValueOption(longOption\x2C\n                                                 optionConfig\x2C\n                                                 result.values);\n    if (mustSetDefault) {\n      storeDefaultOption(longOption\x2C\n                         objectGetOwn(optionConfig\x2C 'default')\x2C\n                         result.values);\n    }\n  });\n\n\n  return result;\n};\n\nmodule.exports = {\n  parseArgs\x2C\n};\n

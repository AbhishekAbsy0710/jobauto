script-source,98,node:internal/util/parse_args/utils,'use strict';\n\nconst {\n  ArrayPrototypeFind\x2C\n  ObjectEntries\x2C\n  ObjectPrototypeHasOwnProperty: ObjectHasOwn\x2C\n  StringPrototypeCharAt\x2C\n  StringPrototypeIncludes\x2C\n  StringPrototypeStartsWith\x2C\n} = primordials;\n\nconst {\n  validateObject\x2C\n} = require('internal/validators');\n\n// These are internal utilities to make the parsing logic easier to read\x2C and\n// add lots of detail for the curious. They are in a separate file to allow\n// unit testing\x2C although that is not essential (this could be rolled into\n// main file and just tested implicitly via API).\n//\n// These routines are for internal use\x2C not for export to client.\n\n/**\n * Return the named property\x2C but only if it is an own property.\n */\nfunction objectGetOwn(obj\x2C prop) {\n  if (ObjectHasOwn(obj\x2C prop))\n    return obj[prop];\n}\n\n/**\n * Return the named options property\x2C but only if it is an own property.\n */\nfunction optionsGetOwn(options\x2C longOption\x2C prop) {\n  if (ObjectHasOwn(options\x2C longOption))\n    return objectGetOwn(options[longOption]\x2C prop);\n}\n\n/**\n * Determines if the argument may be used as an option value.\n * @example\n * isOptionValue('V') // returns true\n * isOptionValue('-v') // returns true (greedy)\n * isOptionValue('--foo') // returns true (greedy)\n * isOptionValue(undefined) // returns false\n */\nfunction isOptionValue(value) {\n  if (value == null) return false;\n\n  // Open Group Utility Conventions are that an option-argument\n  // is the argument after the option\x2C and may start with a dash.\n  return true; // greedy!\n}\n\n/**\n * Detect whether there is possible confusion and user may have omitted\n * the option argument\x2C like `--port --verbose` when `port` of type:string.\n * In strict mode we throw errors if value is option-like.\n */\nfunction isOptionLikeValue(value) {\n  if (value == null) return false;\n\n  return value.length > 1 && StringPrototypeCharAt(value\x2C 0) === '-';\n}\n\n/**\n * Determines if `arg` is just a short option.\n * @example '-f'\n */\nfunction isLoneShortOption(arg) {\n  return arg.length === 2 &&\n    StringPrototypeCharAt(arg\x2C 0) === '-' &&\n    StringPrototypeCharAt(arg\x2C 1) !== '-';\n}\n\n/**\n * Determines if `arg` is a lone long option.\n * @example\n * isLoneLongOption('a') // returns false\n * isLoneLongOption('-a') // returns false\n * isLoneLongOption('--foo') // returns true\n * isLoneLongOption('--foo=bar') // returns false\n */\nfunction isLoneLongOption(arg) {\n  return arg.length > 2 &&\n    StringPrototypeStartsWith(arg\x2C '--') &&\n    !StringPrototypeIncludes(arg\x2C '='\x2C 3);\n}\n\n/**\n * Determines if `arg` is a long option and value in the same argument.\n * @example\n * isLongOptionAndValue('--foo') // returns false\n * isLongOptionAndValue('--foo=bar') // returns true\n */\nfunction isLongOptionAndValue(arg) {\n  return arg.length > 2 &&\n    StringPrototypeStartsWith(arg\x2C '--') &&\n    StringPrototypeIncludes(arg\x2C '='\x2C 3);\n}\n\n/**\n * Determines if `arg` is a short option group.\n *\n * See Guideline 5 of the [Open Group Utility Conventions](https://pubs.opengroup.org/onlinepubs/9699919799/basedefs/V1_chap12.html).\n *   One or more options without option-arguments\x2C followed by at most one\n *   option that takes an option-argument\x2C should be accepted when grouped\n *   behind one '-' delimiter.\n * @example\n * isShortOptionGroup('-a'\x2C {}) // returns false\n * isShortOptionGroup('-ab'\x2C {}) // returns true\n * // -fb is an option and a value\x2C not a short option group\n * isShortOptionGroup('-fb'\x2C {\n *   options: { f: { type: 'string' } }\n * }) // returns false\n * isShortOptionGroup('-bf'\x2C {\n *   options: { f: { type: 'string' } }\n * }) // returns true\n * // -bfb is an edge case\x2C return true and caller sorts it out\n * isShortOptionGroup('-bfb'\x2C {\n *   options: { f: { type: 'string' } }\n * }) // returns true\n */\nfunction isShortOptionGroup(arg\x2C options) {\n  if (arg.length <= 2) return false;\n  if (StringPrototypeCharAt(arg\x2C 0) !== '-') return false;\n  if (StringPrototypeCharAt(arg\x2C 1) === '-') return false;\n\n  const firstShort = StringPrototypeCharAt(arg\x2C 1);\n  const longOption = findLongOptionForShort(firstShort\x2C options);\n  return optionsGetOwn(options\x2C longOption\x2C 'type') !== 'string';\n}\n\n/**\n * Determine if arg is a short string option followed by its value.\n * @example\n * isShortOptionAndValue('-a'\x2C {}); // returns false\n * isShortOptionAndValue('-ab'\x2C {}); // returns false\n * isShortOptionAndValue('-fFILE'\x2C {\n *   options: { foo: { short: 'f'\x2C type: 'string' }}\n * }) // returns true\n */\nfunction isShortOptionAndValue(arg\x2C options) {\n  validateObject(options\x2C 'options');\n\n  if (arg.length <= 2) return false;\n  if (StringPrototypeCharAt(arg\x2C 0) !== '-') return false;\n  if (StringPrototypeCharAt(arg\x2C 1) === '-') return false;\n\n  const shortOption = StringPrototypeCharAt(arg\x2C 1);\n  const longOption = findLongOptionForShort(shortOption\x2C options);\n  return optionsGetOwn(options\x2C longOption\x2C 'type') === 'string';\n}\n\n/**\n * Find the long option associated with a short option. Looks for a configured\n * `short` and returns the short option itself if a long option is not found.\n * @example\n * findLongOptionForShort('a'\x2C {}) // returns 'a'\n * findLongOptionForShort('b'\x2C {\n *   options: { bar: { short: 'b' } }\n * }) // returns 'bar'\n */\nfunction findLongOptionForShort(shortOption\x2C options) {\n  validateObject(options\x2C 'options');\n  const longOptionEntry = ArrayPrototypeFind(\n    ObjectEntries(options)\x2C\n    ({ 1: optionConfig }) => objectGetOwn(optionConfig\x2C 'short') === shortOption\x2C\n  );\n  return longOptionEntry?.[0] ?? shortOption;\n}\n\n/**\n * Check if the given option includes a default value\n * and that option has not been set by the input args.\n * @param {string} longOption - long option name e.g. 'foo'\n * @param {object} optionConfig - the option configuration properties\n * @param {object} values - option values returned in `values` by parseArgs\n */\nfunction useDefaultValueOption(longOption\x2C optionConfig\x2C values) {\n  return objectGetOwn(optionConfig\x2C 'default') !== undefined &&\n    values[longOption] === undefined;\n}\n\nmodule.exports = {\n  findLongOptionForShort\x2C\n  isLoneLongOption\x2C\n  isLoneShortOption\x2C\n  isLongOptionAndValue\x2C\n  isOptionValue\x2C\n  isOptionLikeValue\x2C\n  isShortOptionAndValue\x2C\n  isShortOptionGroup\x2C\n  useDefaultValueOption\x2C\n  objectGetOwn\x2C\n  optionsGetOwn\x2C\n};\n

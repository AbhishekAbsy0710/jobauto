script-source,75,node:internal/main/eval_string,'use strict';\n\n// User passed `-e` or `--eval` arguments to Node without `-i` or\n// `--interactive`.\n\nconst {\n  ObjectDefineProperty\x2C\n  RegExpPrototypeExec\x2C\n  globalThis\x2C\n} = primordials;\n\nconst {\n  prepareMainThreadExecution\x2C\n  markBootstrapComplete\x2C\n} = require('internal/process/pre_execution');\nconst {\n  evalModuleEntryPoint\x2C\n  evalTypeScript\x2C\n  parseAndEvalCommonjsTypeScript\x2C\n  parseAndEvalModuleTypeScript\x2C\n  evalScript\x2C\n} = require('internal/process/execution');\nconst { addBuiltinLibsToObject } = require('internal/modules/helpers');\nconst { getOptionValue } = require('internal/options');\n\nprepareMainThreadExecution();\naddBuiltinLibsToObject(globalThis\x2C '<eval>');\nmarkBootstrapComplete();\n\nconst code = getOptionValue('--eval');\n\nconst print = getOptionValue('--print');\nconst shouldLoadESM = getOptionValue('--import').length > 0 || getOptionValue('--experimental-loader').length > 0;\nconst inputType = getOptionValue('--input-type');\nconst tsEnabled = getOptionValue('--experimental-strip-types');\nif (inputType === 'module') {\n  evalModuleEntryPoint(code\x2C print);\n} else if (inputType === 'module-typescript' && tsEnabled) {\n  parseAndEvalModuleTypeScript(code\x2C print);\n} else {\n  // For backward compatibility\x2C we want the identifier crypto to be the\n  // `node:crypto` module rather than WebCrypto.\n  const isUsingCryptoIdentifier = RegExpPrototypeExec(/\\bcrypto\\b/\x2C code) !== null;\n  const shouldDefineCrypto = isUsingCryptoIdentifier && internalBinding('config').hasOpenSSL;\n\n  if (isUsingCryptoIdentifier && !shouldDefineCrypto) {\n    // This is taken from `addBuiltinLibsToObject`.\n    const object = globalThis;\n    const name = 'crypto';\n    const setReal = (val) => {\n      // Deleting the property before re-assigning it disables the\n      // getter/setter mechanism.\n      delete object[name];\n      object[name] = val;\n    };\n    ObjectDefineProperty(object\x2C name\x2C { __proto__: null\x2C set: setReal });\n  }\n\n  let evalFunction;\n  if (inputType === 'commonjs') {\n    evalFunction = evalScript;\n  } else if (inputType === 'commonjs-typescript' && tsEnabled) {\n    evalFunction = parseAndEvalCommonjsTypeScript;\n  } else if (tsEnabled) {\n    evalFunction = evalTypeScript;\n  } else {\n    // Default to commonjs.\n    evalFunction = evalScript;\n  }\n\n  evalFunction('[eval]'\x2C\n               shouldDefineCrypto ? (\n                 print ? `let crypto=require("node:crypto");{${code}}` : `(crypto=>{{${code}}})(require('node:crypto'))`\n               ) : code\x2C\n               getOptionValue('--inspect-brk')\x2C\n               print\x2C\n               shouldLoadESM);\n}\n

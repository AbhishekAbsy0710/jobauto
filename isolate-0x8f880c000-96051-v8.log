script-source,99,node:internal/util/diff,'use strict';\n\nconst {\n  ArrayIsArray\x2C\n  ArrayPrototypeReverse\x2C\n} = primordials;\n\nconst { validateStringArray\x2C validateString } = require('internal/validators');\nconst { myersDiff } = require('internal/assert/myers_diff');\n\nfunction validateInput(value\x2C name) {\n  if (!ArrayIsArray(value)) {\n    validateString(value\x2C name);\n    return;\n  }\n\n  validateStringArray(value\x2C name);\n}\n\n/**\n * Generate a difference report between two values\n * @param {Array | string} actual - The first value to compare\n * @param {Array | string} expected - The second value to compare\n * @returns {Array} - An array of differences between the two values.\n * The returned data is an array of arrays\x2C where each sub-array has two elements:\n * 1. The operation to perform: -1 for delete\x2C 0 for no-op\x2C 1 for insert\n * 2. The value to perform the operation on\n */\nfunction diff(actual\x2C expected) {\n  if (actual === expected) {\n    return [];\n  }\n\n  validateInput(actual\x2C 'actual');\n  validateInput(expected\x2C 'expected');\n\n  return ArrayPrototypeReverse(myersDiff(actual\x2C expected));\n}\n\nmodule.exports = {\n  diff\x2C\n};\n
